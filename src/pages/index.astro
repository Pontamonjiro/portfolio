---
import BaseLayout from '../layouts/BaseLayout.astro';
import WorkCard from '../components/WorkCard.astro';
import { SITE } from '../site.config';
import { works } from '../data/works';
---

<BaseLayout>
  <header class="hero">
    <div class="container">
      <h1 class="hero__title">{SITE.title}</h1>
      <p class="hero__lead">{SITE.description}</p>
    </div>
  </header>

  <main class="container">
    <section>
      <h2 class="section__title">制作物</h2>
      <ul class="grid">
        {
          works.map((work) => (
            <li>
              <WorkCard work={work} />
            </li>
          ))
        }
      </ul>
    </section>
  </main>

  <footer class="footer">
    <div class="container">
      <small>© {SITE.author}</small>
    </div>
  </footer>
</BaseLayout>

<style>
  .hero {
    padding: 4rem 0 2.5rem;
    border-bottom: 1px solid var(--color-border);
  }
  .hero__title {
    margin: 0 0 0.5rem;
    font-size: clamp(2rem, 5vw, 3rem);
  }
  .hero__lead {
    margin: 0;
    color: var(--color-muted);
    font-size: 1.1rem;
  }
  .section__title {
    margin: 2.5rem 0 1.25rem;
    font-size: 1.4rem;
  }
  .grid {
    list-style: none;
    padding: 0;
    margin: 0 0 4rem;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 1.5rem;
  }
  .footer {
    border-top: 1px solid var(--color-border);
    padding: 2rem 0;
    color: var(--color-muted);
  }
</style>
