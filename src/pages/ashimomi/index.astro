---
// 癒し処 あしもみ本舗 メインLP（写真主役・上品スタイル）。
// 旧・和風版は /ashimomi/washi/ にアーカイブ。
// 写真はフリー素材(Pexels/商用可)のダミー。本番は実店舗の写真に差し替える。
import { ashimomi as shop } from '../../data/shops/ashimomi';

const B = import.meta.env.BASE_URL;
const img = (name: string) => `${B}images/lp/${name}`;
const back = `${B}ashimomi/washi/`;

const menu = shop.fallbackMenu?.[0];
const tel = shop.tel;
// ダミー番号(全部0)はそれっぽく整形して表示（本番は実番号に差し替え）
const telDisp = /^0+$/.test(tel)
  ? '000-0000-0000'
  : tel.replace(/(\d{2,4})(\d{3,4})(\d{4})$/, '$1-$2-$3');

// 装飾用の小さなボタニカル（左右対称の葉）
const leafSvg = `<svg viewBox="0 0 64 40" fill="currentColor" aria-hidden="true">
  <circle cx="32" cy="5" r="2.2"/>
  <path d="M32 8 C32 19 32 30 32 39" stroke="currentColor" stroke-width="1" fill="none"/>
  <ellipse cx="23" cy="15" rx="7.5" ry="2.6" transform="rotate(-28 23 15)"/>
  <ellipse cx="41" cy="15" rx="7.5" ry="2.6" transform="rotate(28 41 15)"/>
  <ellipse cx="21" cy="25" rx="6" ry="2.3" transform="rotate(-24 21 25)"/>
  <ellipse cx="43" cy="25" rx="6" ry="2.3" transform="rotate(24 43 25)"/>
</svg>`;

// LINEアイコン（メイン連絡先として目立たせる用）
const lineIcon = `<svg viewBox="0 0 24 24" width="19" height="19" fill="currentColor" aria-hidden="true"><path d="M12 2C6.48 2 2 5.64 2 10.13c0 4.02 3.55 7.39 8.35 8.03.32.07.77.21.88.49.1.25.07.64.03.89l-.14.85c-.04.25-.2.99.86.54 1.06-.45 5.7-3.36 7.78-5.75C21.1 13.66 22 11.99 22 10.13 22 5.64 17.52 2 12 2z"/></svg>`;
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="color-scheme" content="light only" />
    <link rel="icon" type="image/svg+xml" href={`${B}favicon.svg`} />
    <title>{shop.name}｜{shop.tagline}</title>
    <meta name="description" content={shop.description} />
    <meta property="og:title" content={`${shop.name}｜${shop.tagline}`} />
    <meta property="og:description" content={shop.description} />
    <meta property="og:type" content="website" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@400;500;600&family=Shippori+Mincho:wght@500;600;700&family=Noto+Sans+JP:wght@300;400;500&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <!-- ヘッダー -->
    <header class="hd">
      <div class="hd-logo">{shop.name}</div>
      <a class="hd-cta" href={shop.lineUrl} target="_blank" rel="noopener"><Fragment set:html={lineIcon} />LINEで予約</a>
    </header>

    <!-- ヒーロー -->
    <section class="hero">
      <img class="hero-img" src={img('room-jp.jpg')} alt="" />
      <div class="hero-veil"></div>
      <div class="hero-inner">
        <p class="eyebrow">{shop.tagline}</p>
        <h1 class="hero-title" set:html={shop.hero?.title ?? shop.name} />
        <p class="hero-sub">{shop.hero?.titleSub}</p>
        <div class="hero-btns">
          <a class="btn btn-line-g" href={shop.lineUrl} target="_blank" rel="noopener"><Fragment set:html={lineIcon} />LINEで予約する</a>
          <a class="btn btn-line2" href={`tel:${tel}`}>お電話でも可</a>
        </div>
      </div>
      <a class="hero-scroll" href="#concept" aria-label="下へスクロール"><span>Scroll</span></a>
    </section>

    <!-- コンセプト -->
    <section class="concept" id="concept">
      <div class="leaf"><Fragment set:html={leafSvg} /></div>
      <p class="sec-en">CONCEPT</p>
      <h2 class="sec-jp">心と体を、ほどく時間。</h2>
      <p class="concept-lead">{shop.hero?.lead ?? shop.description}</p>
    </section>

    <!-- メニュー -->
    <section class="menu">
      <div class="menu-head">
        <p class="sec-en">MENU</p>
        <h2 class="sec-jp">メニュー</h2>
      </div>
      <div class="menu-card">
        <div class="menu-photo"><img src={img('massage-jp.jpg')} alt="" loading="lazy" /></div>
        <div class="menu-body">
          <h3 class="menu-name">{menu?.name}</h3>
          <p class="menu-desc">{menu?.desc}</p>
          <div class="menu-price">
            <span class="yen">¥</span>{(menu?.price ?? '').replace(/[¥円]/g, '')}
            <small>（税込・一律）</small>
          </div>
          <a class="btn btn-line-g sm" href={shop.lineUrl} target="_blank" rel="noopener"><Fragment set:html={lineIcon} />LINEで予約する</a>
        </div>
      </div>
    </section>

    <!-- 店内・について -->
    <section class="about">
      <div class="about-photo"><img src={img('tea-jp.jpg')} alt="" loading="lazy" /></div>
      <div class="about-text">
        <p class="sec-en">ABOUT</p>
        <h2 class="sec-jp">その日の体に、<br />合わせて。</h2>
        <p>
          決まった手順をなぞるのではなく、お話を伺い、体に触れて、その日の状態に合わせて圧と時間を調整します。肩・背中・腰から脚先まで、全身をていねいに。
        </p>
        <ul class="about-points">
          <li>オーダーメイドの全身もみほぐし</li>
          <li>受付 {shop.hoursNote}</li>
          <li>一律料金（¥{(menu?.price ?? '').replace(/[¥円]/g, '')}）でわかりやすく</li>
        </ul>
      </div>
    </section>

    <!-- ペット同伴（売り）：看板犬の写真を背景に敷く（黒オーバーレイ＋白文字） -->
    <section class="pet">
      <img class="pet-bg" src={img('dog-sleep.jpg')} alt="お店の看板犬（黒柴）" loading="lazy" />
      <div class="pet-veil"></div>
      <div class="pet-inner">
        <p class="sec-en">With your pet</p>
        <h2 class="sec-jp">大切な家族（ペット）も、ご一緒に。</h2>
        <p class="pet-lead" set:html={shop.petNote.replace('（事前に', '<br>（事前に')} />
      </div>
    </section>

    <!-- お客様の声 -->
    <section class="voices">
      <p class="sec-en">VOICE</p>
      <h2 class="sec-jp">お客様の声</h2>
      <div class="voice-grid">
        {
          shop.voices.slice(0, 3).map((v) => (
            <figure class="voice">
              <blockquote>{v.quote}</blockquote>
              <figcaption>― {v.who}</figcaption>
            </figure>
          ))
        }
      </div>
    </section>

    <!-- アクセス（地図埋め込み） -->
    <section class="access">
      <div class="access-text">
        <p class="sec-en">Access</p>
        <h2 class="sec-jp">アクセス</h2>
        <p class="access-addr">{shop.address}</p>
        {shop.access && <p class="access-sub">{shop.access}</p>}
        <p class="access-sub">受付 {shop.hoursNote}</p>
        <p class="access-note">
          {shop.closedNote}です。当日の営業状況・臨時休業は <strong>Googleマップ</strong> でご確認ください。
        </p>
        <a class="btn btn-ghost" href={shop.mapUrl} target="_blank" rel="noopener">Googleマップで営業状況を見る</a>
      </div>
      <div class="access-map">
        {
          shop.mapEmbed && (
            <iframe src={shop.mapEmbed} loading="lazy" title={`${shop.name}の地図`} />
          )
        }
      </div>
    </section>

    <!-- 連絡先フッター -->
    <footer class="ft">
      <div class="leaf"><Fragment set:html={leafSvg} /></div>
      <p class="ft-logo">{shop.name}</p>
      <p class="ft-lead">ご予約・お問い合わせは <strong>LINE</strong> がいちばん簡単です。</p>
      <div class="ft-btns">
        <a class="btn btn-line-g lg" href={shop.lineUrl} target="_blank" rel="noopener">
          <Fragment set:html={lineIcon} />LINEで予約・相談
        </a>
      </div>
      <div class="ft-sub">
        <a class="btn btn-ghost" href={shop.mapUrl} target="_blank" rel="noopener">Googleマップ（営業状況）</a>
        <a class="ft-tel" href={`tel:${tel}`}>お電話：{telDisp}</a>
      </div>
      <p class="ft-note">
        {shop.closedNote}です。当日の営業状況・臨時休業は Googleマップ でご確認ください。
      </p>
    </footer>

    <style>
      :root {
        --paper: #fbf7ef;
        --cream: #f6f0e7;
        --cream2: #ece0cd;
        --ink: #3c342b;
        --muted: #8c7e6c;
        --brown: #a47d54;
        --brown-d: #835f3c;
        --gold: #c7ad84;
        --line: rgba(60, 52, 43, 0.14);
        --line-green: #06c755;
        --line-green-d: #05a847;
      }
      * { box-sizing: border-box; margin: 0; padding: 0; }
      body {
        font-family: 'Noto Sans JP', sans-serif;
        color: var(--ink);
        background: var(--cream);
        line-height: 1.95;
        font-weight: 300;
        -webkit-font-smoothing: antialiased;
      }
      img { display: block; max-width: 100%; }
      .mincho, h1, h2, h3 { font-family: 'Shippori Mincho', serif; font-weight: 600; }
      .sec-en {
        font-family: 'Cormorant Garamond', serif;
        font-size: 14px; letter-spacing: 0.42em; color: var(--brown);
        text-transform: uppercase; margin-bottom: 10px;
      }
      /* 中央寄せ見出しは英字ラベルの両脇に金の飾り線を添える（統一感＋上品さ） */
      .concept .sec-en, .menu-head .sec-en, .voices .sec-en, .pet .sec-en, .about .sec-en {
        display: inline-flex; align-items: center; justify-content: center; gap: 14px;
      }
      .concept .sec-en::before, .concept .sec-en::after,
      .menu-head .sec-en::before, .menu-head .sec-en::after,
      .voices .sec-en::before, .voices .sec-en::after,
      .pet .sec-en::before, .pet .sec-en::after,
      .about .sec-en::before, .about .sec-en::after {
        content: ''; width: 28px; height: 1px; background: currentColor; opacity: 0.45;
      }
      .sec-jp { font-family: 'Shippori Mincho', serif; font-size: clamp(22px, 3.2vw, 30px); line-height: 1.5; }
      .leaf { color: var(--gold); width: 46px; margin: 0 auto 14px; }
      .leaf svg { width: 100%; height: auto; }

      /* ボタン */
      .btn {
        display: inline-flex; align-items: center; justify-content: center; gap: 8px;
        font-size: 14px; letter-spacing: 0.08em; text-decoration: none; white-space: nowrap;
        padding: 14px 30px; border-radius: 2px; transition: 0.25s; font-weight: 400;
      }
      .btn svg { width: 18px; height: 18px; flex-shrink: 0; }
      .btn-fill { background: var(--brown); color: #fff; }
      .btn-fill:hover { background: var(--brown-d); }
      .btn-fill.sm { padding: 11px 24px; font-size: 13px; }
      /* LINE（メイン連絡先）。palette に馴染む上品なブラウン＋LINEアイコンで主役感を出す */
      .btn-line-g { background: var(--brown); color: #fff; }
      .btn-line-g:hover { background: var(--brown-d); }
      .btn-line-g.sm { padding: 11px 24px; font-size: 13px; }
      .btn-line-g.lg { padding: 17px 42px; font-size: 16px; box-shadow: 0 12px 28px rgba(131, 95, 60, 0.22); }
      .btn-line2 { border: 1px solid #fff; color: #fff; }
      .btn-line2:hover { background: rgba(255, 255, 255, 0.15); }
      .btn-ghost { border: 1px solid var(--brown); color: var(--brown); }
      .btn-ghost:hover { background: var(--brown); color: #fff; }

      /* ヘッダー */
      .hd {
        position: absolute; top: 0; left: 0; right: 0; z-index: 5;
        display: flex; align-items: center; justify-content: space-between;
        padding: 22px clamp(20px, 5vw, 56px);
      }
      .hd-logo {
        font-family: 'Shippori Mincho', serif; font-weight: 700; font-size: 20px;
        letter-spacing: 0.14em; color: #fff; text-shadow: 0 2px 12px rgba(0, 0, 0, 0.4);
      }
      .hd-cta {
        display: inline-flex; align-items: center; gap: 7px;
        font-size: 13px; letter-spacing: 0.06em; text-decoration: none; color: #fff; font-weight: 500;
        background: rgba(255, 255, 255, 0.14); border: 1px solid rgba(255, 255, 255, 0.6);
        padding: 8px 18px; border-radius: 999px; backdrop-filter: blur(2px);
      }
      .hd-cta:hover { background: rgba(255, 255, 255, 0.24); }
      .hd-cta svg { width: 15px; height: 15px; }
      .hd-cta { white-space: nowrap; }

      /* ヒーロー */
      .hero { position: relative; height: min(88vh, 760px); overflow: hidden; display: flex; align-items: center; }
      .hero-img { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; }
      .hero-veil {
        position: absolute; inset: 0;
        background: linear-gradient(90deg, rgba(40, 30, 20, 0.55), rgba(40, 30, 20, 0.12) 60%, transparent),
          linear-gradient(0deg, rgba(40, 30, 20, 0.35), transparent 40%);
      }
      .hero-inner { position: relative; z-index: 2; color: #fff; padding: 0 clamp(24px, 7vw, 90px); max-width: 760px; }
      .hero .eyebrow {
        display: inline-flex; align-items: center; gap: 14px;
        font-family: 'Cormorant Garamond', serif; letter-spacing: 0.3em; font-size: 15px;
        color: #f3e3cf; margin-bottom: 20px; text-transform: none;
      }
      .hero .eyebrow::before { content: ''; width: 38px; height: 1px; background: var(--gold); }
      .hero-title {
        font-family: 'Shippori Mincho', serif; font-weight: 600;
        font-size: clamp(38px, 6.6vw, 74px); line-height: 1.42; text-shadow: 0 2px 24px rgba(0, 0, 0, 0.34);
      }
      .hero-sub { margin-top: 18px; font-size: 15px; letter-spacing: 0.1em; color: #f0e6d8; }
      .hero-btns { margin-top: 36px; display: flex; gap: 14px; flex-wrap: wrap; }
      /* スクロール誘導（ヒーロー下中央） */
      .hero-scroll {
        position: absolute; left: 50%; bottom: 26px; transform: translateX(-50%); z-index: 3;
        display: inline-flex; flex-direction: column; align-items: center; gap: 8px;
        font-family: 'Cormorant Garamond', serif; font-size: 11px; letter-spacing: 0.34em;
        text-transform: uppercase; color: #f3e3cf; text-decoration: none; opacity: 0.85;
      }
      /* letter-spacingの末尾字間ぶん文字が左に寄るので、同量を字下げして下の縦線と中央を合わせる */
      .hero-scroll span { text-indent: 0.34em; }
      .hero-scroll::after {
        content: ''; width: 1px; height: 40px;
        background: linear-gradient(#f3e3cf, transparent);
        animation: scrollPulse 2.2s ease-in-out infinite;
      }
      @keyframes scrollPulse { 0%, 100% { transform: scaleY(0.5); opacity: 0.4; transform-origin: top; } 50% { transform: scaleY(1); opacity: 1; transform-origin: top; } }
      @media (prefers-reduced-motion: reduce) { .hero-scroll::after { animation: none; } }

      /* コンセプト（明るいpaperで抜く） */
      .concept { text-align: center; padding: clamp(48px, 7vw, 84px) 24px; background: var(--paper); }
      .concept-lead { max-width: 30em; margin: 22px auto 0; color: #5c5346; font-size: 16px; }

      /* メニュー（標準cream） */
      .menu { background: var(--cream); padding: clamp(56px, 7vw, 90px) 24px; }
      .menu-head { text-align: center; margin-bottom: 46px; }
      .menu-card {
        max-width: 880px; margin: 0 auto; background: #fff;
        display: grid; grid-template-columns: 0.9fr 1.1fr; overflow: hidden;
        border-radius: 3px; box-shadow: 0 24px 60px rgba(60, 45, 30, 0.1);
      }
      .menu-photo { position: relative; min-height: 300px; }
      .menu-photo img { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; }
      .menu-body { padding: clamp(28px, 4vw, 46px); }
      .menu-name { font-size: 24px; margin-bottom: 12px; }
      .menu-desc { color: var(--muted); font-size: 14.5px; }
      .menu-meta { margin-top: 14px; font-size: 13px; color: var(--muted); letter-spacing: 0.04em; }
      .menu-meta .dot { margin: 0 10px; color: var(--gold); }
      .menu-price {
        font-family: 'Cormorant Garamond', serif; font-size: 46px; color: var(--brown-d);
        margin: 14px 0 22px; line-height: 1; display: flex; align-items: baseline; gap: 2px;
      }
      .menu-price .yen { font-size: 26px; }
      .menu-price small { font-family: 'Noto Sans JP'; font-size: 12px; color: var(--muted); margin-left: 10px; font-weight: 300; }
      .menu-note { max-width: 880px; margin: 22px auto 0; font-size: 12.5px; color: var(--muted); text-align: center; }

      /* About */
      .about { display: grid; grid-template-columns: 1fr 1fr; align-items: stretch; }
      .about-photo { min-height: 420px; position: relative; }
      .about-photo img { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; }
      .about-text { padding: clamp(48px, 7vw, 96px) clamp(28px, 6vw, 80px); align-self: center; }
      /* ABOUTラベル＋見出しは他セクションと同様に中央寄せ（本文・箇条書きは左のまま） */
      .about-text .sec-en { display: flex; }
      .about-text h2 { margin-bottom: 20px; text-align: center; }
      .about-text p { color: #5c5346; font-size: 15px; }
      .about-points { list-style: none; margin-top: 24px; display: grid; gap: 10px; }
      .about-points li { position: relative; padding-left: 22px; font-size: 14px; color: #5c5346; }
      .about-points li::before { content: '✦'; position: absolute; left: 0; color: var(--gold); }

      /* Voices（一段濃いcream2でメリハリ） */
      .voices { text-align: center; padding: clamp(56px, 7vw, 90px) 24px; background: var(--cream2); }
      .voice-grid {
        max-width: 1000px; margin: 44px auto 0; display: grid;
        grid-template-columns: repeat(3, 1fr); gap: 26px;
      }
      .voice {
        background: #fff; border: 1px solid var(--line); border-radius: 3px;
        padding: 38px 34px; text-align: left;
      }
      .voice blockquote {
        font-family: 'Shippori Mincho', serif; font-size: 16px; line-height: 1.9; color: var(--ink);
      }
      .voice blockquote::before { content: '“'; color: var(--gold); font-size: 28px; margin-right: 2px; }
      .voice figcaption { margin-top: 16px; font-size: 12.5px; color: var(--muted); letter-spacing: 0.06em; }

      /* Footer */
      .ft { text-align: center; background: var(--cream2); padding: clamp(60px, 8vw, 96px) 24px 70px; }
      .ft-logo { font-family: 'Shippori Mincho', serif; font-weight: 700; font-size: 26px; letter-spacing: 0.14em; }
      .ft-lead { margin: 22px 0 18px; font-size: 15px; color: var(--ink); }
      .ft-lead strong { color: var(--brown-d); font-weight: 700; }
      .ft-tel {
        font-size: 14px; color: var(--brown-d); text-decoration: none;
        border-bottom: 1px solid var(--gold); padding-bottom: 2px;
      }
      .ft-btns { display: flex; gap: 14px; justify-content: center; flex-wrap: wrap; margin: 0 0 18px; }
      .ft-sub { display: flex; gap: 18px; justify-content: center; align-items: center; flex-wrap: wrap; }
      .ft-note {
        max-width: 32em; margin: 20px auto 0; font-size: 12.5px; color: var(--muted); line-height: 1.8;
      }
      .ft-info { font-size: 13px; color: #5c5346; line-height: 1.9; }
      .ft-back { display: inline-block; margin-top: 26px; font-size: 13px; color: var(--brown); text-decoration: none; border-bottom: 1px solid var(--gold); padding-bottom: 2px; }
      .ft-demo { margin-top: 28px; font-size: 11px; color: #a99c88; }

      /* ペット同伴（看板犬の写真を背景に敷く＝黒オーバーレイ＋白文字） */
      .pet { position: relative; overflow: hidden; text-align: center; color: #fff; padding: clamp(46px, 6.5vw, 74px) 24px; }
      .pet-bg { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; object-position: 50% 42%; }
      .pet-veil { position: absolute; inset: 0; background: linear-gradient(rgba(30, 24, 18, 0.42), rgba(30, 24, 18, 0.54)); }
      .pet-inner { position: relative; z-index: 2; }
      .pet .sec-en { color: #f1e4d0; }
      .pet .sec-jp { color: #fff; text-shadow: 0 2px 16px rgba(0, 0, 0, 0.3); }
      .pet-lead { max-width: 30em; margin: 18px auto 0; color: #f2e9dc; font-size: 15px; }

      /* アクセス（地図・明るいpaper） */
      .access { display: grid; grid-template-columns: 0.92fr 1.08fr; align-items: stretch; background: var(--paper); }
      .access-text { padding: clamp(48px, 7vw, 90px) clamp(28px, 6vw, 72px); align-self: center; }
      .access-addr { font-size: 16px; margin-top: 6px; }
      .access-sub { color: var(--muted); font-size: 14px; margin-top: 4px; }
      .access-note {
        margin-top: 16px; font-size: 13px; color: var(--brown-d); line-height: 1.8;
        background: var(--cream); border-left: 3px solid var(--gold); padding: 11px 15px; border-radius: 2px;
      }
      .access-text .btn { margin-top: 20px; }
      .access-map { position: relative; min-height: 380px; }
      .access-map iframe { position: absolute; inset: 0; width: 100%; height: 100%; border: 0; }

      @media (max-width: 760px) {
        .access { grid-template-columns: 1fr; }
