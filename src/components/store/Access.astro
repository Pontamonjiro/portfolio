---
import type { Shop } from '../../data/shops/types';

interface Props {
  shop: Shop;
}

const { shop } = Astro.props;
---

<section id="info">
  <div class="wrap">
    <div class="sec-head">
      <span class="sec-num">其の四</span>
      <h2>店舗案内</h2>
      <span class="en">ACCESS</span>
    </div>
    <div class="info-grid">
      <table class="info-table">
        <tr><th>店名</th><td>{shop.name}</td></tr>
        <tr><th>住所</th><td>{shop.address}</td></tr>
        {shop.access && (
          <tr>
            <th>アクセス</th>
            <td>{shop.access}</td>
          </tr>
        )}
        <tr>
          <th>受付時間</th>
          <td>
            {shop.hoursNote}<br />
            <span class="live">▶ 当日の営業状況・臨時休業は下の地図（Googleマップ）でご確認ください</span>
          </td>
        </tr>
        <tr>
          <th>定休日</th>
          <td>
            {shop.closedNote}<br />
            <span class="live">▶ 最新の休業日はGoogleマップ／LINEでお知らせしています</span>
          </td>
        </tr>
        <tr><th>ご予約</th><td>完全予約制（LINE・お電話）</td></tr>
        <tr><th>お支払い</th><td>{shop.payment}</td></tr>
        <tr><th>ペット</th><td>{shop.petNote}</td></tr>
        <tr><th>駐車場</th><td>{shop.parking}</td></tr>
      </table>

      <div class="map-embed">
        {
          shop.mapEmbed ? (
            <iframe
              src={shop.mapEmbed}
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"
              title={`${shop.name}の地図`}
            />
          ) : (
            <div class="map-placeholder">
              <span class="mincho">Googleマップを埋め込み</span>
              <small>
                本番ではGoogleビジネスプロフィールの<br />
                埋め込みiframeをここに貼ります。<br />
                営業時間・臨時休業・電話番号は<br />
                Google側から自動表示されます。
              </small>
            </div>
          )
        }
      </div>
    </div>
  </div>
</section>

<style>
  .info-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 50px;
    align-items: start;
  }
  .info-table {
    width: 100%;
    border-collapse: collapse;
  }
  .info-table th,
  .info-table td {
    text-align: left;
    padding: 16px 4px;
    border-bottom: 1px solid var(--line);
    vertical-align: top;
    font-size: 15px;
  }
  .info-table th {
    width: 120px;
    font-family: 'Shippori Mincho', serif;
    font-weight: 600;
    color: var(--kakishibu);
  }
  .info-table .live {
    color: var(--wakatake);
    font-size: 13px;
  }
  .map-embed {
    aspect-ratio: 4 / 3;
    border: 1px solid var(--line);
    border-radius: 2px;
    overflow: hidden;
    background: var(--washi-2);
  }
  .map-embed iframe {
    width: 100%;
    height: 100%;
    border: 0;
    display: block;
  }
  .map-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-direction: column;
    gap: 10px;
    color: var(--ink-soft);
    text-align: center;
    padding: 20px;
  }
  .map-placeholder .mincho {
    font-size: 18px;
    color: var(--sumi);
  }
  .map-placeholder small {
    font-size: 12px;
    letter-spacing: 0.06em;
    line-height: 1.7;
  }

  @media (max-width: 820px) {
    .info-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
