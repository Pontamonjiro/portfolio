---
import type { Shop } from '../../data/shops/types';

interface Props {
  shop: Shop;
}

const { shop } = Astro.props;
---

<section class="voices" id="voices">
  <div class="wrap">
    <div class="sec-head">
      <span class="sec-num">其の三</span>
      <h2>お客様の声</h2>
      <span class="en">VOICE</span>
    </div>
    <div class="voice-grid">
      {
        shop.voices.map((v) => (
          <div class="voice">
            <p class="quote">{v.quote}</p>
            <p class="who">― {v.who}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>

<style>
  .voices {
    background: var(--washi-2);
  }
  .voices .sec-num {
    color: var(--wakatake);
  }
  .voices .sec-head h2 {
    color: var(--sumi);
  }
  .voice-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 28px;
  }
  .voice {
    border: 1px solid var(--line);
    padding: 32px;
    border-radius: 2px;
    background: var(--washi);
  }
  .voice .quote {
    font-family: 'Shippori Mincho', serif;
    font-size: 18px;
    line-height: 1.9;
    margin-bottom: 18px;
    color: var(--sumi);
  }
  .voice .quote::before {
    content: '「';
    color: var(--kakishibu);
  }
  .voice .quote::after {
    content: '」';
    color: var(--kakishibu);
  }
  .voice .who {
    font-size: 13px;
    letter-spacing: 0.08em;
    color: var(--ink-soft);
  }

  @media (max-width: 820px) {
    .voice-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
