---
import type { Shop } from '../../data/shops/types';

interface Props {
  shop: Shop;
}

const { shop } = Astro.props;
---

<div class="sticky-bar">
  <a href={`tel:${shop.tel}`} class="s-tel">
    <svg viewBox="0 0 24 24" fill="currentColor"
      ><path
        d="M6.62 10.79a15.5 15.5 0 006.59 6.59l2.2-2.2a1 1 0 011.02-.24 11.4 11.4 0 003.57.57 1 1 0 011 1V20a1 1 0 01-1 1A17 17 0 013 4a1 1 0 011-1h3.5a1 1 0 011 1c0 1.25.2 2.45.57 3.57a1 1 0 01-.25 1.02l-2.2 2.2z"
      ></path></svg
    >
    電話する
  </a>
  <a href={shop.lineUrl} class="s-line" target="_blank" rel="noopener">
    <svg viewBox="0 0 24 24" fill="currentColor"
      ><path
        d="M12 2C6.48 2 2 5.64 2 10.13c0 4.02 3.55 7.39 8.35 8.03.32.07.77.21.88.49.1.25.07.64.03.89l-.14.85c-.04.25-.2.99.86.54 1.06-.45 5.7-3.36 7.78-5.75C21.1 13.66 22 11.99 22 10.13 22 5.64 17.52 2 12 2z"
      ></path></svg
    >
    LINEで予約
  </a>
</div>

<style>
  .sticky-bar {
    position: fixed;
    left: 0;
    right: 0;
    bottom: 0;
    z-index: 60;
    display: none;
    grid-template-columns: 1fr 1fr;
    background: var(--washi);
    border-top: 1px solid var(--line);
    box-shadow: 0 -4px 16px rgba(28, 42, 48, 0.08);
  }
  .sticky-bar a {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    padding: 16px 8px;
    text-decoration: none;
    font-size: 15px;
    font-weight: 600;
    letter-spacing: 0.04em;
  }
  .sticky-bar a svg {
    width: 18px;
    height: 18px;
  }
  .sticky-bar .s-tel {
    color: var(--kakishibu);
    border-right: 1px solid var(--line);
  }
  .sticky-bar .s-line {
    color: #fff;
    background: var(--line-green);
  }

  @media (max-width: 820px) {
    .sticky-bar {
      display: grid;
    }
  }
</style>
