---
import { href } from '../site.config';
import type { Work } from '../data/works';

interface Props {
  work: Work;
}

const { work } = Astro.props;
const link = href(`${work.slug}/`);
---

<a class="card" href={link}>
  {work.thumbnail && <img class="card__thumb" src={href(work.thumbnail)} alt="" />}
  <div class="card__body">
    <h2 class="card__title">{work.title}</h2>
    <p class="card__desc">{work.description}</p>
    {
      work.tags && (
        <ul class="card__tags">
          {work.tags.map((tag) => (
            <li class="card__tag">{tag}</li>
          ))}
        </ul>
      )
    }
  </div>
</a>

<style>
  .card {
    display: block;
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    overflow: hidden;
    text-decoration: none;
    color: inherit;
    transition: transform 0.15s ease, box-shadow 0.15s ease;
    background: #fff;
  }
  .card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 24px rgba(0, 0, 0, 0.08);
  }
  .card__thumb {
    width: 100%;
    aspect-ratio: 16 / 9;
    object-fit: cover;
  }
  .card__body {
    padding: 1rem 1.25rem 1.25rem;
  }
  .card__title {
    margin: 0 0 0.4rem;
    font-size: 1.1rem;
  }
  .card__desc {
    margin: 0;
    color: var(--color-muted);
    font-size: 0.95rem;
  }
  .card__tags {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin: 0.8rem 0 0;
    padding: 0;
  }
  .card__tag {
    font-size: 0.75rem;
    color: var(--color-accent);
    border: 1px solid var(--color-border);
    border-radius: 999px;
    padding: 0.1rem 0.6rem;
  }
</style>
